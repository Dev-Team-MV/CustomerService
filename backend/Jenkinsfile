// Jenkinsfile para CustomerService - backend
// Jobs en Jenkins: CustomerService-Backend-Develop (BD Atlas dev) | CustomerService-Backend-Production (BD VPS pdn)
// Develop → apicsdev.michelangelodelvalle.com:5001 | Production → apics.michelangelodelvalle.com:5000
// FRONTEND_URL: base pública del SPA (SMS setup-password). Si el job define FRONTEND_URL en Jenkins, se respeta.
// SPAs públicos: devlakewoodp1/lakewoodp1 | devlakewoodp2/lakewoodp2 | devcrm/crm (michelangelodelvalle.com).
// API: apicsdev/apics. Otros (new.*): define FRONTEND_URL manualmente en el job si aplica.
// Tag de imagen: solo un ":" (ej. customerservice-backend:development-1)
//
// IMPORTANTE: Solo se ejecuta si hay cambios en backend/. Si el commit solo toca frontend/, se omite.

pipeline {
    agent any

    environment {
        APP_DIR = 'backend'
        JWT_SECRET = 'supersecretkey123456789'
        TWILIO_PHONE_FROM = '+18327707897'
        GCS_PROJECT_ID = 'centurions-car-wash-442201'
        GCS_BUCKET_NAME = 'customer-service-7cc'
        GCS_MAKE_PUBLIC = 'false'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // Solo seguir si hubo cambios en backend/ — si el commit solo toca frontend/, se omite todo el pipeline
        stage('Check changes') {
            steps {
                script {
                    env.SHOULD_RUN = 'false'
                    def changed = sh(script: """
                        if [ -n \"${env.GIT_PREVIOUS_COMMIT ?: ''}\" ] && [ \"${env.GIT_PREVIOUS_COMMIT}\" != \"${env.GIT_COMMIT ?: ''}\" ]; then
                            git diff --name-only \"${env.GIT_PREVIOUS_COMMIT}\" \"${env.GIT_COMMIT}\" 2>/dev/null || true
                        else
                            (git rev-parse --quiet --verify HEAD~1 >/dev/null 2>&1 && git diff --name-only HEAD~1 HEAD) || echo 'backend/'
                        fi
                    """, returnStdout: true).trim()
                    def hasBackendChanges = changed.split('\n').findAll { it.trim() }.any { it.startsWith('backend/') }
                    env.SHOULD_RUN = hasBackendChanges ? 'true' : 'false'
                    echo "Changed files: ${changed.replace('\n', ', ')}"
                    echo "SHOULD_RUN (backend): ${env.SHOULD_RUN}"
                    if (env.SHOULD_RUN == 'false') {
                        currentBuild.description = 'Skipped (no backend changes)'
                    }
                }
            }
        }

        stage('Set environment') {
            when { expression { env.SHOULD_RUN == 'true' } }
            steps {
                script {
                    def branch = env.BRANCH_NAME ?: env.GIT_BRANCH?.replaceFirst('^origin/', '') ?: 'develop'
                    def jobName = (env.JOB_NAME ?: '').toLowerCase()
                    // El ambiente lo define el JOB: Dev job = siempre BD dev; Prod job = siempre BD pdn (dev NUNCA apunta a pdn)
                    def isProdJob = jobName.contains('production') || jobName.contains('prod') || jobName.contains('pdn')
                    def isDevJob = jobName.contains('development') || jobName.contains('dev')
                    // Solo disparar el ambiente correcto según la rama (evitar deploy equivocado si el job se configuró mal)
                    if (isDevJob && branch != 'develop') {
                        error "Job Develop solo debe ejecutarse con rama 'develop'. Rama actual: ${branch}. Revisa Branch Specifier del job (debe ser */develop)."
                    }
                    if (isProdJob && branch != 'main' && branch != 'master') {
                        error "Job Production solo debe ejecutarse con rama 'main' (o 'master'). Rama actual: ${branch}. Revisa Branch Specifier del job (debe ser */main)."
                    }
                    if (isDevJob) {
                        env.IS_PRODUCTION = 'false'
                    } else if (isProdJob) {
                        env.IS_PRODUCTION = 'true'
                    } else {
                        env.IS_PRODUCTION = (env.DEPLOY_ENV == 'production' || branch == 'main').toString()
                    }
                    env.ENVIRONMENT = (env.IS_PRODUCTION == 'true') ? 'production' : 'development'
                    env.CONTAINER_NAME = (env.IS_PRODUCTION == 'true') ? 'backend' : 'backend-dev'
                    env.APP_PORT = (env.IS_PRODUCTION == 'true') ? '5000' : '5001'
                    env.IMAGE_NAME = 'customerservice-backend'
                    env.IMAGE_TAG = "${env.ENVIRONMENT}-${env.BUILD_NUMBER}"
                    env.PUBLIC_URL = (env.IS_PRODUCTION == 'true') ? 'https://apics.michelangelodelvalle.com' : 'https://apicsdev.michelangelodelvalle.com'
                    // FRONTEND_URL: si el job Jenkins ya la define (Environment), se usa; si no, se infiere por nombre del job
                    def fe = (env.FRONTEND_URL ?: '').trim()
                    if (!fe) {
                        def jn = (env.JOB_NAME ?: '').toLowerCase()
                        def prod = env.IS_PRODUCTION == 'true'
                        if (jn.contains('mvcrm') || jn.contains('mv-crm') || jn.contains('mv_crm')) {
                            fe = prod ? 'https://crm.michelangelodelvalle.com' : 'https://devcrm.michelangelodelvalle.com'
                        } else if (jn.contains('phase2') || jn.contains('phase-2') || jn.contains('fase2')
                                || jn.contains('lakewoodp2') || jn.contains('lakewood-p2')) {
                            fe = prod ? 'https://lakewoodp2.michelangelodelvalle.com' : 'https://devlakewoodp2.michelangelodelvalle.com'
                        } else {
                            fe = prod ? 'https://lakewoodp1.michelangelodelvalle.com' : 'https://devlakewoodp1.michelangelodelvalle.com'
                        }
                    }
                    env.FRONTEND_URL = fe
                    def uriPdn = 'mongodb://mongo_customerservice:WmSld1ZrUWzWcaDZ6QBKl7QDKQsMnPfp@72.61.6.13:27017/customerservice?authSource=admin'
                    def uriDev = 'mongodb+srv://customerservicemichelangelo_db_user:lRNMjO5qLRGD6csL@customerservice.mkutnlt.mongodb.net/customerservice'
                    env.MONGODB_URI = (env.IS_PRODUCTION == 'true') ? uriPdn : uriDev
                    // --- Logs para verificar configuración ---
                    echo "========== CONFIGURACIÓN BACKEND =========="
                    echo "Job name: ${env.JOB_NAME}"
                    echo "Rama: ${branch}"
                    echo "Ambiente resuelto por: ${isDevJob ? 'job (dev)' : isProdJob ? 'job (prod)' : 'rama'}"
                    echo "IS_PRODUCTION: ${env.IS_PRODUCTION}"
                    echo "ENVIRONMENT: ${env.ENVIRONMENT}"
                    echo "Contenedor: ${env.CONTAINER_NAME} | Puerto: ${env.APP_PORT}"
                    echo "BD: ${env.IS_PRODUCTION == 'true' ? 'VPS pdn (72.61.6.13:27017/customerservice)' : 'Atlas dev (customerservice.mkutnlt.mongodb.net)'}"
                    echo "Imagen: ${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                    echo "FRONTEND_URL (SMS setup): ${env.FRONTEND_URL}"
                    echo "==========================================="
                }
            }
        }

        stage('Install') {
            when { expression { env.SHOULD_RUN == 'true' } }
            steps {
                dir(env.APP_DIR) {
                    sh '''#!/bin/bash
                        set -e
                        mkdir -p "${WORKSPACE}/.nvm"
                        export NVM_DIR="${WORKSPACE}/.nvm"
                        curl -sSf -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
                        [ -s "$NVM_DIR/nvm.sh" ] && \\. "$NVM_DIR/nvm.sh"
                        nvm install 20
                        nvm use 20
                        npm ci
                    '''
                }
            }
        }

        stage('Build Docker') {
            when { expression { env.SHOULD_RUN == 'true' } }
            steps {
                dir(env.APP_DIR) {
                    sh "docker build -t ${env.IMAGE_NAME}:${env.IMAGE_TAG} ."
                }
            }
        }

        stage('Deploy') {
            when { expression { env.SHOULD_RUN == 'true' } }
            steps {
                script {
                    withCredentials([
                        string(credentialsId: 'twilio-account-sid', variable: 'TWILIO_ACCOUNT_SID'),
                        string(credentialsId: 'twilio-auth-token', variable: 'TWILIO_AUTH_TOKEN'),
                        string(credentialsId: 'gcs-credentials-json', variable: 'GCS_CREDENTIALS')
                    ]) {
                        sh "docker stop ${env.CONTAINER_NAME} 2>/dev/null || true"
                        sh "docker rm ${env.CONTAINER_NAME} 2>/dev/null || true"
                        sh '''
                            printf 'GCS_CREDENTIALS=%s\\n' "$GCS_CREDENTIALS" > "${WORKSPACE}/backend/gcs.env"
                            docker run -d \
                              --name ''' + env.CONTAINER_NAME + ''' \
                              --network deploy_app-network \
                              -p ''' + env.APP_PORT + ''':5000 \
                              -e NODE_ENV=''' + (env.IS_PRODUCTION == 'true' ? 'production' : 'development') + ''' \
                              -e PORT=5000 \
                              -e PUBLIC_URL=''' + env.PUBLIC_URL + ''' \
                              -e FRONTEND_URL=''' + env.FRONTEND_URL + ''' \
                              -e MONGODB_URI="$MONGODB_URI" \
                              -e JWT_SECRET=''' + env.JWT_SECRET + ''' \
                              -e TWILIO_ACCOUNT_SID=$TWILIO_ACCOUNT_SID \
                              -e TWILIO_AUTH_TOKEN=$TWILIO_AUTH_TOKEN \
                              -e TWILIO_PHONE_FROM=''' + env.TWILIO_PHONE_FROM + ''' \
                              -e GCS_PROJECT_ID=''' + env.GCS_PROJECT_ID + ''' \
                              -e GCS_BUCKET_NAME=''' + env.GCS_BUCKET_NAME + ''' \
                              -e GCS_MAKE_PUBLIC=''' + env.GCS_MAKE_PUBLIC + ''' \
                              --env-file "${WORKSPACE}/backend/gcs.env" \
                              --restart unless-stopped \
                              ''' + env.IMAGE_NAME + ':' + env.IMAGE_TAG + '''
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo "========== DESPLIEGUE OK =========="
            echo "Ambiente: ${env.ENVIRONMENT} | Contenedor: ${env.CONTAINER_NAME} | Puerto: ${env.APP_PORT}"
            echo "URL local: http://localhost:${env.APP_PORT}"
            echo "BD usada: ${env.ENVIRONMENT == 'production' ? 'VPS pdn' : 'Atlas dev'}"
            echo "MONGODB_URI: ${env.MONGODB_URI}"
            echo "===================================="
        }
        failure {
            echo 'Falló el pipeline'
        }
    }
}
