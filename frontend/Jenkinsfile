// Jobs: 8 pipelines (4 apps × 2 ambientes)
// - CustomerService-Frontend-Lakewood-Develop  → frontend-dev:5174 (rama develop)
// - CustomerService-Frontend-Lakewood-Production → frontend:5173 (rama main)
// - CustomerService-Frontend-MVCRM-Develop     → frontend-mvcrm-dev:5179 (rama develop)
// - CustomerService-Frontend-MVCRM-Production   → frontend-mvcrm-pdn:5180 (rama main)
// - CustomerService-Frontend-Phase2-Develop      → frontend-phase2-dev:5181 (rama develop)
// - CustomerService-Frontend-Phase2-Production   → frontend-phase2-pdn:5182 (rama main)
// - CustomerService-Frontend-6Town-Develop       → frontend-6town-dev:5183 (rama develop)
// - CustomerService-Frontend-6Town-Production    → frontend-6town-pdn:5184 (rama main)
//
// URLs: devcustomerservice / customerservice (lakewood) | mvcrmdev / mvcrm (mv-crm)
// Backend: apicsdev / apics
//
// IMPORTANTE: Solo se ejecuta si hay cambios en frontend/ (apps o shared). Si el commit solo toca backend/, se omite.
pipeline {
  agent any

  parameters {
    choice(
      name: 'APP_NAME',
      choices: ['lakewood-p1', 'mv-crm', 'phase-2', '6town-houses'],
      description: 'App a construir (se puede sobrescribir por nombre del Job)'
    )
    string(
      name: 'PROJECT_ID',
      defaultValue: '',
      description: 'Opcional: sobrescribe VITE_PROJECT_ID para el build'
    )
  }

  options {
    timeout(time: 15, unit: 'MINUTES')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    // Detectar app y ambiente por nombre del Job (prioridad) o por parámetro
    stage('Set environment') {
      steps {
        script {
          def branch = env.BRANCH_NAME ?: env.GIT_BRANCH?.replaceFirst('^origin/', '') ?: 'develop'
          def jobName = (env.JOB_NAME ?: '').toLowerCase()
          def isProdJob = jobName.contains('production') || jobName.contains('prod') || jobName.contains('pdn')
          def isDevJob = jobName.contains('development') || jobName.contains('develop') || jobName.endsWith('-dev') || jobName.contains('-dev-')

          // Detectar app por nombre del Job
          if (jobName.contains('lakewood') || jobName.contains('lakewood-p1')) {
            env.APP_NAME = 'lakewood-p1'
          } else if (jobName.contains('mvcrm') || jobName.contains('mv-crm') || jobName.contains('mv_crm')) {
            env.APP_NAME = 'mv-crm'
          } else if (jobName.contains('phase2') || jobName.contains('phase-2') || jobName.contains('fase2')) {
            env.APP_NAME = 'phase-2'
          } else if (jobName.contains('6town') || jobName.contains('6-town') || jobName.contains('sixtown')) {
            env.APP_NAME = '6town-houses'
          } else {
            env.APP_NAME = params.APP_NAME ?: 'lakewood-p1'
          }

          if (isDevJob && branch != 'develop') {
            error "Job Develop solo debe ejecutarse con rama 'develop'. Rama actual: ${branch}."
          }
          if (isProdJob && branch != 'main' && branch != 'master') {
            error "Job Production solo debe ejecutarse con rama 'main' (o 'master'). Rama actual: ${branch}."
          }

          env.IS_PRODUCTION = isProdJob ? 'true' : (isDevJob ? 'false' : (branch == 'main' ? 'true' : 'false'))
          env.ENVIRONMENT = (env.IS_PRODUCTION == 'true') ? 'production' : 'development'

          // Contenedores y puertos por app + ambiente
          // Lakewood (app principal): frontend/frontend-dev, customer-service-frontend, 5173/5174
          // MVCRM: frontend-mvcrm-dev/pdn, customer-service-mvcrm-frontend, 5179/5180
          // Phase-2: frontend-phase2-dev/pdn, customer-service-phase2-frontend, 5181/5182
          // 6town-houses: frontend-6town-dev/pdn, customer-service-6town-frontend, 5183/5184
          if (env.APP_NAME == 'lakewood-p1') {
            env.CONTAINER_NAME = env.ENVIRONMENT == 'production' ? 'frontend' : 'frontend-dev'
            env.IMAGE_NAME = 'customer-service-frontend'
          } else if (env.APP_NAME == 'mv-crm') {
            env.CONTAINER_NAME = "frontend-mvcrm-${env.ENVIRONMENT == 'production' ? 'pdn' : 'dev'}"
            env.IMAGE_NAME = 'customer-service-mvcrm-frontend'
          } else if (env.APP_NAME == 'phase-2') {
            env.CONTAINER_NAME = "frontend-phase2-${env.ENVIRONMENT == 'production' ? 'pdn' : 'dev'}"
            env.IMAGE_NAME = 'customer-service-phase2-frontend'
          } else if (env.APP_NAME == '6town-houses') {
            env.CONTAINER_NAME = "frontend-6town-${env.ENVIRONMENT == 'production' ? 'pdn' : 'dev'}"
            env.IMAGE_NAME = 'customer-service-6town-frontend'
          } else {
            error "APP_NAME no soportada: ${env.APP_NAME}"
          }
          env.IMAGE_TAG = "${env.ENVIRONMENT}-${env.BUILD_NUMBER}"

          def ports = [
            'lakewood-p1': [dev: '5174', prod: '5173'],
            'mv-crm': [dev: '5179', prod: '5180'],
            'phase-2': [dev: '5181', prod: '5182'],
            '6town-houses': [dev: '5183', prod: '5184']
          ]
          def appPorts = ports[env.APP_NAME]
          if (!appPorts) {
            error "Puertos no definidos para app '${env.APP_NAME}'. Verifica que develop tenga el Jenkinsfile con soporte 6town-houses y vuelve a ejecutar."
          }
          env.APP_PORT = env.IS_PRODUCTION == 'true' ? appPorts.prod : appPorts.dev

          env.VITE_API_URL = env.IS_PRODUCTION == 'true'
            ? 'https://apics.michelangelodelvalle.com/api'
            : 'https://apicsdev.michelangelodelvalle.com/api'

          // Resolver VITE_PROJECT_ID:
          // prioridad 1) parámetro PROJECT_ID, 2) variable del Job (VITE_PROJECT_ID), 3) default por app.
          // mv-crm puede operar como CRM global; solo usa este valor para asociar SMS/registro si está configurado.
          def defaultProjectIds = [
            'lakewood-p1': '69a73ce5b20401b061da6451',
            'phase-2'    : '69b9b2188186434073c6b13d',
            '6town-houses': '69e623d8699902a57559b557'
          ]
          def resolvedProjectId = (params.PROJECT_ID ?: '').trim()
          if (!resolvedProjectId) resolvedProjectId = (env.VITE_PROJECT_ID ?: '').trim()
          if (!resolvedProjectId) resolvedProjectId = defaultProjectIds[env.APP_NAME] ?: ''
          def requiresProjectId = env.APP_NAME != 'mv-crm'
          if (!resolvedProjectId && requiresProjectId) {
            error "VITE_PROJECT_ID no definido para app '${env.APP_NAME}'. Configure PROJECT_ID (param) o VITE_PROJECT_ID (env del job)."
          }
          env.VITE_PROJECT_ID = resolvedProjectId

          env.SHOULD_RUN = 'true'

          echo "========== CONFIGURACIÓN FRONTEND =========="
          echo "Job: ${env.JOB_NAME} | Rama: ${branch}"
          echo "App: ${env.APP_NAME} | Ambiente: ${env.ENVIRONMENT}"
          echo "Contenedor: ${env.CONTAINER_NAME} | Puerto: ${env.APP_PORT}"
          echo "API: ${env.VITE_API_URL}"
          echo "PROJECT_ID: ${env.VITE_PROJECT_ID}"
          echo "============================================="
        }
      }
    }

    // Solo seguir si hubo cambios en frontend/ — si el commit solo toca backend/, se omite todo el pipeline
    stage('Check changes') {
      steps {
        script {
          env.SHOULD_RUN = 'false'
          def changed = sh(script: """
            if [ -n \"${env.GIT_PREVIOUS_COMMIT ?: ''}\" ] && [ \"${env.GIT_PREVIOUS_COMMIT}\" != \"${env.GIT_COMMIT ?: ''}\" ]; then
              git diff --name-only \"${env.GIT_PREVIOUS_COMMIT}\" \"${env.GIT_COMMIT}\" 2>/dev/null || true
            else
              (git rev-parse --quiet --verify HEAD~1 >/dev/null 2>&1 && git diff --name-only HEAD~1 HEAD) || echo 'frontend/'
            fi
          """, returnStdout: true).trim()

          def appPath = "frontend/apps/${env.APP_NAME}/"
          def sharedPath = "frontend/shared/"
          def hasFrontendChanges = changed.split('\n').findAll { it.trim() }.any { f ->
            f.startsWith('frontend/') && (f.startsWith(appPath) || f.startsWith(sharedPath))
          }
          env.SHOULD_RUN = hasFrontendChanges ? 'true' : 'false'

          echo "Changed files: ${changed.replace('\n', ', ')}"
          echo "SHOULD_RUN (${env.APP_NAME} o shared): ${env.SHOULD_RUN}"
          if (env.SHOULD_RUN == 'false') {
            currentBuild.description = "Skipped (no changes in ${env.APP_NAME} or shared)"
          }
        }
      }
    }

    stage('Install') {
      when { expression { env.SHOULD_RUN == 'true' } }
      steps {
        dir("frontend/apps/${env.APP_NAME}") {
          sh '''#!/bin/bash
            set -e
            mkdir -p "${WORKSPACE}/.nvm"
            export NVM_DIR="${WORKSPACE}/.nvm"
            curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
            [ -s "$NVM_DIR/nvm.sh" ] && \\. "$NVM_DIR/nvm.sh"
            nvm install 20
            nvm use 20
            npm ci
          '''
        }
      }
    }

    stage('Build Docker Image') {
      when { expression { env.SHOULD_RUN == 'true' } }
      steps {
        dir('frontend') {
          script {
            def buildArgs = [
              "VITE_API_URL=${env.VITE_API_URL}",
              "VITE_PROJECT_ID=${env.VITE_PROJECT_ID}"
            ]
            def dockerfileByApp = [
              'lakewood-p1': 'Dockerfile',
              'mv-crm': 'apps/mv-crm/Dockerfile',
              'phase-2': 'apps/phase-2/Dockerfile',
              '6town-houses': 'apps/6town-houses/Dockerfile'
            ]
            def dockerfile = dockerfileByApp[env.APP_NAME]
            if (!dockerfile) {
              error "Dockerfile no definido para app '${env.APP_NAME}'"
            }
            echo "Build Docker: ${env.IMAGE_NAME}:${env.IMAGE_TAG} (${env.APP_NAME})"
            def buildArgFlags = buildArgs.collect { "--build-arg \"${it}\"" }.join(' ')
            sh "docker build --no-cache -f ${dockerfile} -t ${env.IMAGE_NAME}:${env.IMAGE_TAG} ${buildArgFlags} ."
          }
        }
      }
    }

    stage('Deploy') {
      when { expression { env.SHOULD_RUN == 'true' } }
      steps {
        script {
          sh "docker stop ${env.CONTAINER_NAME} 2>/dev/null || true"
          sh "docker rm ${env.CONTAINER_NAME} 2>/dev/null || true"
          sh """
            docker run -d \
              --name ${env.CONTAINER_NAME} \
              -p ${env.APP_PORT}:80 \
              --restart unless-stopped \
              ${env.IMAGE_NAME}:${env.IMAGE_TAG}
          """
        }
      }
    }
  }

  post {
    success {
      echo "Frontend ${env.APP_NAME} (${env.ENVIRONMENT}) desplegado en http://localhost:${env.APP_PORT}"
    }
    always {
      cleanWs()
    }
  }
}
